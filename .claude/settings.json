{
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "WebFetch(domain:localhost)",
      "WebFetch",
      "NotebookEdit",
      "Bash",
      "Agent",
      "TodoWrite",
      "WebSearch"
    ],
    "deny": []
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "AskUserQuestion|EnterPlanMode|ExitPlanMode|mcp__pixsim__.*",
        "hooks": [
          {
            "type": "command",
            "command": "python -m pixsim7.client.hook_pretool"
          }
        ]
      }
    ]
  }
}