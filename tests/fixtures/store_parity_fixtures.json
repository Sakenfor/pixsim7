{
  "version": "1.1",
  "comment": "Shared TS<->Py parity scenarios for the GameObject store. Used by packages/game/engine/src/__tests__/storeParity.test.ts and pixsim7/backend/tests/services/game/test_store_parity.py. Operations limited to upsert / remove (both impls expose verbatim). After the canonical cutover (v1.1), legacy flags.inventory/flags.npcs are no longer hydrated and no inventory mirror is maintained. Non-deterministic gameObjects.meta.updatedAt is intentionally NOT asserted.",
  "scenarios": [
    {
      "name": "upsert-single-item",
      "world_id": 1,
      "initial_flags": {},
      "operations": [
        {
          "op": "upsert",
          "objects": [
            {
              "kind": "item",
              "id": "flower",
              "name": "Flower",
              "itemData": {"itemDefId": "flower", "quantity": 3}
            }
          ]
        }
      ],
      "expect": {
        "canonical_refs": ["item:flower"],
        "items": [
          {"ref": "item:flower", "name": "Flower", "quantity": 3}
        ]
      }
    },
    {
      "name": "upsert-then-remove",
      "world_id": 1,
      "initial_flags": {},
      "operations": [
        {
          "op": "upsert",
          "objects": [
            {
              "kind": "item",
              "id": "flower",
              "name": "Flower",
              "itemData": {"itemDefId": "flower", "quantity": 1}
            }
          ]
        },
        {"op": "remove", "refs": ["item:flower"]}
      ],
      "expect": {
        "canonical_refs": [],
        "items": []
      }
    },
    {
      "name": "upsert-npc-with-components-preserved-on-read",
      "world_id": 1,
      "initial_flags": {},
      "operations": [
        {
          "op": "upsert",
          "objects": [
            {
              "kind": "npc",
              "id": 12,
              "name": "Bob",
              "components": [
                {"type": "narrative", "enabled": true, "data": {"active_program_id": "p"}}
              ]
            }
          ]
        }
      ],
      "expect": {
        "canonical_refs": ["npc:12"],
        "npcs": [
          {
            "ref": "npc:12",
            "name": "Bob",
            "components_by_type": {"narrative": {"active_program_id": "p"}}
          }
        ]
      }
    }
  ]
}
