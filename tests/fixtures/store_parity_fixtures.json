{
  "version": "1.0",
  "comment": "Shared TS<->Py parity scenarios for the GameObject store. Used by packages/game/engine/src/__tests__/storeParity.test.ts and pixsim7/backend/tests/services/game/test_store_parity.py. Operations are limited to ops both impls expose verbatim (upsert / remove). Each scenario asserts on canonical refs, item/npc fields, and the temporary flags.inventory mirror. Non-deterministic gameObjects.meta.updatedAt is intentionally NOT asserted.",
  "scenarios": [
    {
      "name": "upsert-single-item",
      "world_id": 1,
      "initial_flags": {},
      "operations": [
        {
          "op": "upsert",
          "objects": [
            {
              "kind": "item",
              "id": "flower",
              "name": "Flower",
              "itemData": {"itemDefId": "flower", "quantity": 3}
            }
          ]
        }
      ],
      "expect": {
        "canonical_refs": ["item:flower"],
        "items": [
          {"ref": "item:flower", "name": "Flower", "quantity": 3}
        ],
        "mirror_items": [
          {"id": "flower", "itemId": "flower", "qty": 3, "quantity": 3}
        ]
      }
    },
    {
      "name": "upsert-then-remove",
      "world_id": 1,
      "initial_flags": {},
      "operations": [
        {
          "op": "upsert",
          "objects": [
            {
              "kind": "item",
              "id": "flower",
              "name": "Flower",
              "itemData": {"itemDefId": "flower", "quantity": 1}
            }
          ]
        },
        {"op": "remove", "refs": ["item:flower"]}
      ],
      "expect": {
        "canonical_refs": [],
        "items": [],
        "mirror_items": []
      }
    },
    {
      "name": "legacy-inventory-hydrated-as-canonical-items",
      "world_id": 1,
      "initial_flags": {
        "inventory": {
          "items": [
            {"id": "flower", "qty": 2},
            {"id": "key", "qty": 1}
          ]
        }
      },
      "operations": [],
      "expect": {
        "canonical_refs": ["item:flower", "item:key"],
        "items": [
          {"ref": "item:flower", "quantity": 2},
          {"ref": "item:key", "quantity": 1}
        ]
      }
    },
    {
      "name": "canonical-overrides-legacy-on-ref-conflict",
      "world_id": 1,
      "initial_flags": {
        "inventory": {"items": [{"id": "flower", "qty": 1}]}
      },
      "operations": [
        {
          "op": "upsert",
          "objects": [
            {
              "kind": "item",
              "id": "flower",
              "name": "Canonical Flower",
              "itemData": {"itemDefId": "flower", "quantity": 9}
            }
          ]
        }
      ],
      "expect": {
        "canonical_refs": ["item:flower"],
        "items": [
          {"ref": "item:flower", "name": "Canonical Flower", "quantity": 9}
        ],
        "mirror_items": [
          {"id": "flower", "quantity": 9}
        ]
      }
    },
    {
      "name": "legacy-npc-hydrated",
      "world_id": 1,
      "initial_flags": {
        "npcs": {"npc:7": {"name": "Alex", "role": "barista"}}
      },
      "operations": [],
      "expect": {
        "canonical_refs": ["npc:7"],
        "npcs": [
          {"ref": "npc:7", "name": "Alex", "role": "barista"}
        ]
      }
    },
    {
      "name": "upsert-npc-with-components-preserved-on-read",
      "world_id": 1,
      "initial_flags": {},
      "operations": [
        {
          "op": "upsert",
          "objects": [
            {
              "kind": "npc",
              "id": 12,
              "name": "Bob",
              "components": [
                {"type": "narrative", "enabled": true, "data": {"active_program_id": "p"}}
              ]
            }
          ]
        }
      ],
      "expect": {
        "canonical_refs": ["npc:12"],
        "npcs": [
          {
            "ref": "npc:12",
            "name": "Bob",
            "components_by_type": {"narrative": {"active_program_id": "p"}}
          }
        ]
      }
    }
  ]
}
