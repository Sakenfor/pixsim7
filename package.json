{
  "name": "@pixsim7/workspace",
  "private": true,
  "version": "0.0.0",
  "workspaces": [
    "apps/*",
    "packages/*/*"
  ],
  "scripts": {
    "dev": "pnpm -r --parallel dev",
    "build": "pnpm -r build",
    "build:ext": "pnpm --filter @pixsim7/chrome-extension build",
    "dev:ext": "pnpm --filter @pixsim7/chrome-extension dev",
    "build:deps": "pnpm -r --filter @pixsim7/types --filter @pixsim7/ui --filter @pixsim7/game.engine --filter @pixsim7/game.components --filter @pixsim7/interaction.gizmos run build --if-present",
    "build:plugin": "tsx scripts/build-plugin.ts",
    "build:plugins": "tsx scripts/build-plugin.ts --all",
    "build:android": "cd apps/pixsim7-android && gradlew.bat assembleDebug",
    "build:android:release": "cd apps/pixsim7-android && gradlew.bat assembleRelease",
    "install:android": "cd apps/pixsim7-android && adb install app/build/outputs/apk/debug/app-debug.apk",
    "codegen": "tsx tools/codegen/runner.ts",
    "codegen:check": "tsx tools/codegen/runner.ts --check",
    "openapi:gen": "tsx tools/codegen/generate-openapi-types.ts",
    "openapi:check": "tsx tools/codegen/generate-openapi-types.ts --check",
    "branded:gen": "tsx tools/codegen/generate-branded-types.ts",
    "branded:check": "tsx tools/codegen/generate-branded-types.ts --check",
    "composition-roles:gen": "tsx tools/codegen/generate-composition-roles.ts",
    "composition-roles:check": "tsx tools/codegen/generate-composition-roles.ts --check",
    "prompt-roles:gen": "tsx tools/codegen/generate-prompt-roles.ts",
    "prompt-roles:check": "tsx tools/codegen/generate-prompt-roles.ts --check",
    "cue:gen": "tsx tools/codegen/generate-prompt-pack-schemas.ts",
    "cue:check": "tsx tools/codegen/generate-prompt-pack-schemas.ts --check",
    "cue:projection-corpus:gen": "tsx tools/codegen/generate-primitive-projection-corpus.ts",
    "cue:projection-corpus:check": "tsx tools/codegen/generate-primitive-projection-corpus.ts --check",
    "prompt-role-authority:report": "python scripts/check_prompt_role_authority.py",
    "prompt-role-authority:check": "python scripts/check_prompt_role_authority.py --check",
    "upload-context:gen": "tsx tools/codegen/generate-upload-context.ts",
    "upload-context:check": "tsx tools/codegen/generate-upload-context.ts --check",
    "types:gen": "pnpm codegen -- --group types",
    "types:check": "pnpm codegen -- --group types --check",
    "typecheck": "pnpm -r exec tsc --noEmit",
    "lint": "echo 'add lint script per package'",
    "generate-docs": "tsx packages/game/engine/src/utils/generatePluginDocs.ts",
    "generate-registry-docs": "tsx scripts/generate-registry-docs.ts",
    "docs:check": "python scripts/docs_check.py",
    "docs:plans:sync": "python scripts/plan_governance_cli.py sync",
    "docs:plans:check": "python scripts/plan_governance_cli.py check",
    "meta:check": "python scripts/check_plugin_meta_updates.py",
    "docs:app-map": "tsx packages/shared/app-map/src/cli.ts",
    "docs:app-map:check": "tsx packages/shared/app-map/src/cli.ts --check",
    "docs:openapi": "python scripts/gen_openapi_docs.py",
    "test": "pnpm test:registry:gen && python scripts/tests/run.py changed",
    "test:changed": "pnpm test:registry:gen && python scripts/tests/run.py changed",
    "test:list": "pnpm test:registry:gen && python scripts/tests/run.py changed --list",
    "test:list:json": "pnpm test:registry:gen && python scripts/tests/run.py changed --list --json",
    "test:fast": "pnpm test:registry:gen && python scripts/tests/run.py fast",
    "test:project-bundle": "pnpm test:registry:gen && python scripts/tests/run.py project-bundle",
    "test:full": "pnpm test:registry:gen && python scripts/tests/run.py full",
    "test:backend": "pnpm test:registry:gen && python scripts/tests/run.py changed --backend-only",
    "test:frontend": "pnpm test:registry:gen && python scripts/tests/run.py changed --frontend-only",
    "test:registry:gen": "tsx --tsconfig apps/main/tsconfig.app.json scripts/tests/generate_catalog.ts",
    "test:registry:check": "tsx --tsconfig apps/main/tsconfig.app.json scripts/tests/generate_catalog.ts --check && python scripts/tests/validate_catalog.py",
    "test:catalog:gen": "pnpm test:registry:gen",
    "test:catalog:check": "pnpm test:registry:check",
    "test:block-ops:projection:corpus:gen": "pnpm projection-corpus:gen",
    "test:block-ops:projection:corpus:check": "pnpm projection-corpus:check",
    "test:block-ops:projection:eval": "python scripts/tests/block_ops/primitive_projection/eval_primitive_projection.py --threshold 0.45",
    "test:block-ops:projection:eval:medium": "python scripts/tests/block_ops/primitive_projection/eval_primitive_projection.py --threshold 0.45 --corpus scripts/tests/block_ops/primitive_projection/eval_corpus_medium.json --report docs/plans/prompt-primitive-projection-eval-medium.md",
    "db:migrate": "python scripts/migrate_all.py",
    "db:migrate:main": "python scripts/migrate_all.py --scope main",
    "db:migrate:game": "python scripts/migrate_all.py --scope game",
    "db:migrate:blocks": "python scripts/migrate_all.py --scope blocks",
    "db:migrate:logs": "python scripts/migrate_all.py --scope logs"
  },
  "devDependencies": {
    "esbuild": "^0.24.0",
    "orval": "^8.4.0",
    "tsx": "^4.20.6",
    "yaml": "^2.8.0"
  }
}
