{
  "id": "db",
  "category": "core",
  "type": "docker-compose",
  "name": "Databases (Docker)",
  "description": "PostgreSQL and Redis via docker-compose",
  "file": "docker-compose.db-only.yml",
  "ports": [
    {
      "name": "Postgres",
      "env": "POSTGRES_PORT",
      "default_port": 5434,
      "scan_ports": [5432, 5433, 5434, 5435],
      "connection_template": "postgresql://pixsim:pixsim123@127.0.0.1:{port}/pixsim7"
    },
    {
      "name": "Redis",
      "env": "REDIS_PORT",
      "default_port": 6380,
      "scan_ports": [6379, 6380],
      "connection_template": "redis://localhost:{port}/0"
    }
  ],
  "auto_start": false,
  "enabled": true,
  "settings": [
    {
      "key": "postgres_port",
      "type": "number",
      "label": "Postgres Port",
      "description": "Docker-compose port mapping for PostgreSQL",
      "default": 5434,
      "env_export": "POSTGRES_PORT"
    },
    {
      "key": "redis_port",
      "type": "number",
      "label": "Redis Port",
      "description": "Docker-compose port mapping for Redis",
      "default": 6380,
      "env_export": "REDIS_PORT"
    },
    {
      "key": "database_url",
      "type": "string",
      "label": "Main Database URL",
      "description": "PostgreSQL connection for the main pixsim7 database",
      "default": "postgresql://pixsim:pixsim123@127.0.0.1:5434/pixsim7",
      "env_export": "DATABASE_URL"
    },
    {
      "key": "blocks_database_url",
      "type": "string",
      "label": "Blocks Database URL",
      "description": "PostgreSQL for block primitives (empty = use main database)",
      "default": "",
      "env_export": "BLOCKS_DATABASE_URL"
    },
    {
      "key": "log_database_url",
      "type": "string",
      "label": "Log Database URL",
      "description": "PostgreSQL/TimescaleDB for log ingestion (empty = use main database)",
      "default": "",
      "env_export": "LOG_DATABASE_URL"
    },
    {
      "key": "redis_url",
      "type": "string",
      "label": "Redis URL",
      "description": "Redis connection for cache and job queues",
      "default": "redis://localhost:6380/0",
      "env_export": "REDIS_URL"
    }
  ]
}
