{
  "id": "db",
  "category": "core",
  "type": "docker-compose",
  "name": "Databases (Docker)",
  "description": "PostgreSQL and Redis via docker-compose",
  "file": "docker-compose.db-only.yml",
  "ports": [
    {
      "name": "Postgres",
      "env": "POSTGRES_PORT",
      "default_port": 5434,
      "scan_ports": [5432, 5433, 5434, 5435],
      "connection_template": "postgresql://pixsim:pixsim123@127.0.0.1:{port}/pixsim7"
    },
    {
      "name": "Redis",
      "env": "REDIS_PORT",
      "default_port": 6380,
      "scan_ports": [6379, 6380],
      "connection_template": "redis://localhost:{port}/0"
    }
  ],
  "auto_start": false,
  "enabled": true,
  "settings": [
    {
      "key": "postgres_port",
      "type": "number",
      "label": "Postgres Port",
      "description": "PostgreSQL port (requires docker-compose restart)",
      "default": 5434,
      "env_export": "POSTGRES_PORT"
    },
    {
      "key": "redis_port",
      "type": "number",
      "label": "Redis Port",
      "description": "Redis port (requires docker-compose restart)",
      "default": 6380,
      "env_export": "REDIS_PORT"
    }
  ]
}
