{
  "id": "db",
  "category": "core",
  "type": "docker-compose",
  "name": "Databases (Docker)",
  "description": "PostgreSQL and Redis via docker-compose",
  "file": "docker-compose.db-only.yml",
  "ports": [
    {
      "name": "Postgres",
      "env": "POSTGRES_PORT",
      "default_port": 5434,
      "scan_ports": [5432, 5433, 5434, 5435],
      "connection_template": "postgresql://pixsim:pixsim123@127.0.0.1:{port}/pixsim7"
    },
    {
      "name": "Redis",
      "env": "REDIS_PORT",
      "default_port": 6380,
      "scan_ports": [6379, 6380],
      "connection_template": "redis://127.0.0.1:{port}/0"
    }
  ],
  "auto_start": false,
  "enabled": true,
  "settings": [
    {
      "key": "postgres_port",
      "type": "number",
      "label": "Port",
      "description": "Docker-compose port mapping",
      "default": 5434,
      "env_export": "POSTGRES_PORT",
      "section": "Main PostgreSQL"
    },
    {
      "key": "database_url",
      "type": "string",
      "label": "Connection URL",
      "description": "Main pixsim7 database",
      "default": "postgresql://pixsim:pixsim123@127.0.0.1:5434/pixsim7",
      "env_export": "DATABASE_URL",
      "section": "Main PostgreSQL"
    },
    {
      "key": "blocks_database_url",
      "type": "string",
      "label": "Connection URL",
      "description": "Block primitives database (empty = use main)",
      "default": "",
      "env_export": "BLOCKS_DATABASE_URL",
      "section": "Blocks Database"
    },
    {
      "key": "log_database_url",
      "type": "string",
      "label": "Connection URL",
      "description": "TimescaleDB for log ingestion (empty = use main)",
      "default": "",
      "env_export": "LOG_DATABASE_URL",
      "section": "Log Database"
    },
    {
      "key": "redis_port",
      "type": "number",
      "label": "Port",
      "description": "Docker-compose port mapping",
      "default": 6380,
      "env_export": "REDIS_PORT",
      "section": "Redis"
    },
    {
      "key": "redis_url",
      "type": "string",
      "label": "Connection URL",
      "description": "Cache and job queues",
      "default": "redis://127.0.0.1:6380/0",
      "env_export": "REDIS_URL",
      "section": "Redis"
    }
  ]
}
