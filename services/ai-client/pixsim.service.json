{
  "id": "ai-client",
  "category": "services",
  "type": "worker",
  "name": "AI Client (Bridge)",
  "description": "Local agent bridge — connects Claude/Codex CLI sessions to the backend via WebSocket",
  "module": "pixsim7.client",
  "args": ["--url", "ws://localhost:8000/api/v1/ws/agent-cmd"],
  "depends_on": ["main-api"],
  "auto_start": false,
  "enabled": true,
  "exclude_base_settings": ["max_jobs", "job_timeout"],
  "settings": [
    {
      "key": "hook_port",
      "type": "number",
      "label": "Hook Server Port",
      "description": "Port for Claude Code PreToolUse hooks (0 = auto-assign)",
      "default": 0,
      "arg_map": "--hook-port",
      "section": "Connection"
    },
    {
      "key": "shared",
      "type": "boolean",
      "label": "Shared bridge",
      "description": "Run unscoped so the bridge serves any user. Leave off to bind to the launcher's logged-in user.",
      "default": false,
      "arg_map": "--shared",
      "section": "Connection"
    },
    {
      "key": "pool_size",
      "type": "number",
      "label": "Pool Size",
      "description": "Number of parallel CLI sessions",
      "default": 1,
      "arg_map": "--pool-size",
      "section": "Pool"
    },
    {
      "key": "timeout",
      "type": "number",
      "label": "Task Timeout (s)",
      "description": "Maximum seconds per task before timeout",
      "default": 120,
      "arg_map": "--timeout",
      "section": "Pool"
    },
    {
      "key": "hook_tools",
      "type": "multi_select",
      "label": "Claude Built-in Tools",
      "description": "Which Claude Code built-in tools require user approval before execution",
      "options": [
        "Bash", "Write", "Edit", "NotebookEdit",
        "WebFetch", "WebSearch",
        "EnterPlanMode", "ExitPlanMode",
        "Agent", "TodoWrite"
      ],
      "default": ["Bash", "Write", "Edit"],
      "section": "Tool Approval"
    },
    {
      "key": "mcp_approval_tools",
      "type": "multi_select",
      "label": "MCP Tools",
      "description": "Which PixSim MCP tools require confirmation (Claude and Codex)",
      "options": [
        "assets_delete", "assets_archive", "assets_bulk_tags", "assets_reupload",
        "generations_create", "generations_cancel", "generations_delete",
        "generations_chain_execute",
        "plans_create", "plans_update",
        "prompts_apply_edit", "prompts_create_family", "prompts_create_version",
        "species_create", "species_update",
        "notifications_emit", "notifications_create"
      ],
      "default": ["assets_delete", "generations_create", "species_create"],
      "section": "Tool Approval"
    }
  ]
}
