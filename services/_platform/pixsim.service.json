{
  "id": "_platform",
  "type": "platform",
  "name": "Platform",
  "description": "Cross-cutting configuration shared across all services",
  "enabled": true,
  "auto_start": false,
  "settings": [
    {
      "key": "pixsim_home",
      "type": "string",
      "label": "Data Directory",
      "description": "Root directory for all app data (media, logs, cache, settings). Leave empty for OS default.",
      "default": "G:/code/pixsim7/data",
      "env_export": "PIXSIM_HOME",
      "section": "Data"
    },
    {
      "key": "secret_key",
      "type": "string",
      "label": "Secret Key",
      "description": "JWT signing key (change in production)",
      "default": "change-this-in-production",
      "env_export": "SECRET_KEY",
      "section": "Security"
    },
    {
      "key": "cors_origins",
      "type": "string",
      "label": "CORS Origins",
      "description": "Allowed origins (or * for all)",
      "separator": ",",
      "default": "http://localhost:5173,http://localhost:5174,http://localhost:5175,http://localhost:5176,http://localhost:8000,http://localhost:8001,http://localhost:8002,http://localhost:8100,http://localhost:3100",
      "env_export": "CORS_ORIGINS",
      "section": "Security"
    },
    {
      "key": "use_local_datastores",
      "type": "boolean",
      "label": "Use Local Datastores",
      "description": "Skip Docker DB service; use local Postgres/Redis instead",
      "default": false,
      "env_export": "USE_LOCAL_DATASTORES",
      "section": "Data"
    },
    {
      "key": "debug",
      "type": "boolean",
      "label": "Debug Mode",
      "description": "Enable debug mode for backends",
      "default": true,
      "env_export": "DEBUG",
      "section": "Debug"
    },
    {
      "key": "sql_logging",
      "type": "boolean",
      "label": "SQL Logging",
      "description": "Enable SQLAlchemy query echo",
      "default": false,
      "env_export": "SQL_LOGGING_ENABLED",
      "section": "Debug"
    },
    {
      "key": "worker_debug_flags",
      "type": "string",
      "label": "Worker Debug Flags",
      "description": "Comma-separated debug categories (generation, provider, worker)",
      "default": "",
      "env_export": "PIXSIM_WORKER_DEBUG",
      "section": "Debug"
    },
    {
      "key": "health_interval_sec",
      "type": "number",
      "label": "Health Check Interval",
      "description": "Base polling interval in seconds. Lower = more responsive, higher = less CPU/log noise.",
      "default": 2.0,
      "env_export": "PIXSIM_HEALTH_INTERVAL",
      "section": "Observability"
    },
    {
      "key": "health_timeout_sec",
      "type": "number",
      "label": "Health Check Timeout",
      "description": "HTTP timeout per /health request. Raise if backend is slow under DB load (causes flapping).",
      "default": 1.5,
      "env_export": "PIXSIM_HEALTH_TIMEOUT",
      "section": "Observability"
    },
    {
      "key": "log_exclude_paths",
      "type": "string",
      "label": "Log Exclude Paths",
      "description": "Comma-separated HTTP paths dropped from request logs. Default silences routine health-check polling.",
      "default": "/health,/ready,/",
      "env_export": "PIXSIM_LOG_EXCLUDE_PATHS",
      "section": "Observability"
    }
  ]
}
